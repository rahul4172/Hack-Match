PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change_this_to_a_long_random_secret

# Supabase PostgreSQL — Project Settings → Database → Connection string (URI)
# Use "Session mode" pooler for serverless, or direct connection for local dev
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Set to false only for local Postgres without SSL
DATABASE_SSL=true

# Optional — only if you add Supabase client features later
# SUPABASE_URL=https://[PROJECT-REF].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
